{
  "version": "1.0.0",
  "name": "Coding Tools MCP Desktop",
  "productType": "Developer Tool",
  "stack": "svelte",
  "aesthetic": "refined-utilitarian",
  "references": ["Linear", "Raycast", "Vercel Dashboard"],
  "defaultTheme": "dark",
  "colors": {
    "dark": {
      "bg": "oklch(0.13 0.005 260)",
      "bgElevated": "oklch(0.16 0.006 260)",
      "surface": "oklch(0.19 0.008 260)",
      "surfaceHover": "oklch(0.22 0.010 260)",
      "border": "oklch(0.28 0.010 260)",
      "borderSubtle": "oklch(0.24 0.008 260)",
      "text": "oklch(0.97 0.005 260)",
      "textSecondary": "oklch(0.72 0.012 260)",
      "textMuted": "oklch(0.55 0.012 260)",
      "accent": "oklch(0.62 0.18 275)",
      "accentHover": "oklch(0.68 0.20 275)",
      "accentMuted": "oklch(0.62 0.18 275 / 0.15)",
      "success": "oklch(0.72 0.17 155)",
      "warning": "oklch(0.78 0.14 75)",
      "error": "oklch(0.65 0.20 25)",
      "info": "oklch(0.70 0.12 240)"
    },
    "light": {
      "bg": "oklch(0.98 0.004 260)",
      "bgElevated": "oklch(1 0 0)",
      "surface": "oklch(1 0 0)",
      "surfaceHover": "oklch(0.97 0.006 260)",
      "border": "oklch(0.90 0.008 260)",
      "borderSubtle": "oklch(0.94 0.006 260)",
      "text": "oklch(0.18 0.015 260)",
      "textSecondary": "oklch(0.42 0.015 260)",
      "textMuted": "oklch(0.58 0.012 260)",
      "accent": "oklch(0.52 0.20 275)",
      "accentHover": "oklch(0.46 0.22 275)",
      "accentMuted": "oklch(0.52 0.20 275 / 0.10)",
      "success": "oklch(0.55 0.17 155)",
      "warning": "oklch(0.62 0.14 75)",
      "error": "oklch(0.55 0.20 25)",
      "info": "oklch(0.52 0.12 240)"
    },
    "status": {
      "running": "oklch(0.72 0.17 155)",
      "starting": "oklch(0.78 0.14 75)",
      "stopped": "oklch(0.55 0.012 260)",
      "error": "oklch(0.65 0.20 25)"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Plus Jakarta Sans", "PingFang SC", "Microsoft YaHei", "sans-serif"],
      "mono": ["JetBrains Mono", "Cascadia Code", "Consolas", "monospace"]
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.625
    }
  },
  "spacing": {
    "base": 4,
    "scale": [0, 4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96]
  },
  "borderRadius": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "xl": "18px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px oklch(0 0 0 / 0.12)",
    "md": "0 4px 12px oklch(0 0 0 / 0.16)",
    "lg": "0 12px 32px oklch(0 0 0 / 0.24)",
    "glow": "0 0 24px oklch(0.62 0.18 275 / 0.25)"
  },
  "motion": {
    "fast": "150ms",
    "normal": "200ms",
    "slow": "300ms",
    "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "zIndex": {
    "dropdown": 100,
    "sticky": 200,
    "modal": 300,
    "toast": 400,
    "tooltip": 500
  }
}
